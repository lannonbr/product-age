{
  "name": "product-age",
  "version": "0.1.0",
  "main": "index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "nodemon app.js",
    "lint": "npx prettier . --check && npm run stylelint && npm run eslint",
    "eslint": "./node_modules/.bin/eslint .",
    "stylelint": "./node_modules/.bin/stylelint \"statics/css/**/*.css\"",
    "test": "npm run lint"
  },
  "author": "Benjamin Lannon",
  "license": "MIT",
  "description": "A small app to check how old my tech products I own are.",
  "type": "module",
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@fastify/view": "^12.0.0",
    "chart.js": "^4.5.1",
    "dayjs": "^1.11.21",
    "fastify": "^5.8.5",
    "liquidjs": "^10.27.0",
    "webpack": "^5.107.2"
  },
  "devDependencies": {
    "@e18e/eslint-plugin": "^0.5.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-plugin-html": "~8.1.4",
    "globals": "^17.6.0",
    "nodemon": "~3.1.14",
    "prettier": "^3.8.4",
    "stylelint": "~17.13.0",
    "stylelint-config-standard": "~40.0.0"
  },
  "nodemonConfig": {
    "ignore": [
      "public/"
    ],
    "ext": "liquid html js json"
  },
  "private": true
}
